{
  "name": "inventario-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/run-dev-https.js",
    "dev:http": "cross-env VITE_USE_HTTPS=false vite --config vite.config.mjs",
    "dev:tunnel": "concurrently \"npm run dev\" \"node ./scripts/run-tunnel.js\"",
    "dev:ngrok": "concurrently \"npm run dev\" \"node ./scripts/run-ngrok.js\"",
    "ngrok": "node ./scripts/run-ngrok.js",
    "dev:cloudflare": "node ./scripts/run-cloudflared.js",
    "dev:cloudflare:fast": "node ./scripts/run-cloudflared-preview.js",
    "mkcert:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-mkcert.ps1",
    "gen:selfsigned": "node ./scripts/generate-selfsigned.js",
    "dev:https": "cross-env VITE_USE_HTTPS=true vite --config vite.config.mjs",
    "build": "vite build --config vite.config.mjs",
    "preview": "vite preview --config vite.config.mjs",
    "test:excel:engineer": "node ./scripts/test_remove_duplicate_engineer.js"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "@kalimahapps/vue-icons": "^1.9.5",
    "@phosphor-icons/vue": "^2.0.18",
    "@tanstack/vue-query": "^5.92.8",
    "@tanstack/vue-virtual": "^3.13.18",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vueuse/core": "^14.2.0",
    "@vueuse/motion": "^3.0.3",
    "@zxing/browser": "^0.1.5",
    "bwip-js": "^2.0.11",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "flatpickr": "^4.6.13",
    "flowbite": "^4.0.1",
    "flowbite-datepicker": "^2.0.0",
    "gsap": "^3.14.2",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^3.0.4",
    "jspdf-autotable": "^5.0.2",
    "liquid-glass-vue": "^0.0.1",
    "lucide-vue-next": "^0.544.0",
    "notivue": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "pdfmake": "^0.2.20",
    "puppeteer": "^24.31.0",
    "qrcode": "^1.5.4",
    "sweetalert2": "^11.26.0",
    "vue": "^3.5.25",
    "vue-liquid-glass": "^1.0.0",
    "vue-router": "^4.6.4",
    "vue3-toastify": "^0.2.8",
    "xlsx": "^0.18.5",
    "xlsx-populate": "^1.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@typescript-eslint/utils": "^8.53.0",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "localtunnel": "^2.0.2",
    "ngrok": "^5.0.0-beta.2",
    "postcss": "^8.5.6",
    "sass": "^1.94.2",
    "selfsigned": "^2.4.1",
    "sharp": "^0.34.4",
    "tailwindcss": "^4.1.17",
    "terser": "^5.30.3",
    "vite": "^5.4.21"
  }
}
